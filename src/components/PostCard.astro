---
import TagPill from "./TagPill.astro";
import { formatDate, pickTilt, hashString } from "~/lib/utils";

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  tags: string[];
  cover?: string;
  variant?: "paper" | "pink" | "yellow" | "lime" | "violet";
  index?: number;
}
const {
  href,
  title,
  description,
  date,
  tags,
  variant = "paper",
  index = 0,
} = Astro.props;
const tilt = pickTilt(hashString(title) + index);
---

<article
  class:list={["post-card brutal-border-thick brutal-shadow brutal-hover", `card-${variant}`]}
  style={`--tilt:${tilt}deg`}
  data-reveal
  data-post-tags={tags.join(",")}
>
  <a href={href} class="card-link">
    <div class="meta">
      <time class="date" datetime={date.toISOString()}>{formatDate(date)}</time>
      <span class="dot">·</span>
      <span class="hint">read →</span>
    </div>
    <h3 class="title">{title}</h3>
    <p class="desc">{description}</p>
    <div class="tags">
      {tags.map((t) => <TagPill tag={t} />)}
    </div>
  </a>
</article>

<style>
  .post-card {
    background: var(--paper);
    padding: 1.3rem 1.4rem 1.4rem;
    transform: rotate(var(--tilt));
    transition: transform 0.18s ease, box-shadow 0.18s ease;
    display: block;
    position: relative;
  }
  .post-card:hover { z-index: 2; }
  .card-pink { background: var(--accent-1); }
  .card-yellow { background: var(--accent-2); }
  .card-lime { background: var(--accent-3); }
  .card-violet { background: var(--accent-4); color: white; }
  :global(.dark) .card-violet { color: var(--ink); }
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }
  .dot { opacity: 0.5; }
  .hint { font-weight: 700; }
  .title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.2rem, 2vw, 1.6rem);
    line-height: 1.15;
    margin-bottom: 0.7rem;
  }
  .desc {
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 1rem;
    opacity: 0.85;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
</style>
