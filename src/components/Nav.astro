---
import ThemeToggle from "./ThemeToggle.astro";
const path = Astro.url.pathname;
const links = [
  { href: "/", label: "首頁", en: "home" },
  { href: "/blog", label: "文章", en: "blog" },
  { href: "/about", label: "關於", en: "about" },
  { href: "/now", label: "近況", en: "now" },
];
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
---

<header class="nav-shell">
  <nav class="nav brutal-border brutal-shadow-sm">
    <a href="/" class="logo" data-logo aria-label="首頁">
      <span class="logo-mark">E.</span>
      <span class="logo-text">ethan/blog</span>
    </a>
    <ul class="links">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={["link", { active: isActive(l.href) }]}
          >
            <span class="zh">{l.label}</span>
            <span class="en">{l.en}</span>
          </a>
        </li>
      ))}
    </ul>
    <div class="actions">
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
  .nav-shell {
    position: sticky;
    top: 1.2rem;
    z-index: 50;
    padding-inline: 1.2rem;
    margin-top: 1.2rem;
  }
  .nav {
    max-width: 1200px;
    margin: 0 auto;
    background: var(--paper);
    padding: 0.6rem 1rem 0.6rem 1rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }
  .logo {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--font-display);
    cursor: pointer;
    user-select: none;
  }
  .logo-mark {
    background: var(--accent-1);
    border: 2.5px solid var(--ink);
    box-shadow: 3px 3px 0 0 var(--ink);
    padding: 0.1em 0.4em;
    font-weight: 900;
    font-size: 1.1rem;
    transform: rotate(-3deg);
    display: inline-block;
  }
  :global(.dark) .logo-mark { box-shadow: 3px 3px 0 0 var(--accent-2); }
  .logo-text {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }
  .links {
    list-style: none;
    display: flex;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
    justify-content: center;
  }
  .link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.35rem;
    padding: 0.45rem 0.75rem;
    text-decoration: none;
    color: var(--ink);
    border: 2px solid transparent;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .link:hover {
    background: var(--accent-2);
    border-color: var(--ink);
    transform: translate(-1px, -1px);
  }
  .link.active {
    background: var(--accent-1);
    border-color: var(--ink);
  }
  :global(.dark) .link.active { background: var(--accent-2); }
  .link .en {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 0.7rem;
    opacity: 0.6;
  }
  .actions { display: flex; align-items: center; gap: 0.6rem; }

  @media (max-width: 720px) {
    .nav { padding: 0.5rem 0.7rem; gap: 0.5rem; }
    .logo-text { display: none; }
    .links { gap: 0.1rem; }
    .link { padding: 0.35rem 0.55rem; font-size: 0.85rem; }
    .link .en { display: none; }
  }
</style>
