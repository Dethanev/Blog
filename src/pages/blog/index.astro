---
import BaseLayout from "~/layouts/BaseLayout.astro";
import PostCard from "~/components/PostCard.astro";
import TagPill from "~/components/TagPill.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout title="文章" description="所有文章列表">
  <section class="blog-head">
    <div class="head-inner">
      <h1 class="page-title">
        <span class="line">所有</span>
        <span class="line accent">文章</span>
      </h1>
      <p class="page-sub">
        共 <strong>{posts.length}</strong> 篇。點 tag 過濾，再點一次「all」回到全部。
      </p>

      <div class="filter-row">
        <TagPill tag="all" filter active />
        {allTags.map((t) => <TagPill tag={t} filter />)}
      </div>
    </div>
  </section>

  <section class="posts-section">
    <div class="posts-list">
      {posts.map((p, i) => (
        <PostCard
          href={`/blog/${p.id}`}
          title={p.data.title}
          description={p.data.description}
          date={p.data.date}
          tags={p.data.tags}
          variant={p.data.variant}
          index={i}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .blog-head {
    max-width: 1100px;
    margin: 3rem auto 4rem;
    padding: 0 1.5rem;
  }
  .head-inner {
    border-bottom: 4px solid var(--ink);
    padding-bottom: 2rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.04em;
    margin-bottom: 1rem;
  }
  .page-title .line { display: block; }
  .page-title .accent {
    background: var(--accent-1);
    color: var(--ink);
    border: 4px solid var(--ink);
    box-shadow: 8px 8px 0 0 var(--ink);
    padding: 0 0.15em;
    display: inline-block;
    transform: rotate(-1.5deg);
    margin-top: 0.1em;
  }
  :global(.dark) .page-title .accent {
    box-shadow: 8px 8px 0 0 var(--accent-2);
  }
  .page-sub {
    font-size: 1rem;
    margin-bottom: 1.6rem;
    max-width: 50ch;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .posts-section {
    max-width: 1100px;
    margin: 0 auto 6rem;
    padding: 0 1.5rem;
  }
  .posts-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.8rem;
  }

  @media (max-width: 720px) {
    .posts-list { grid-template-columns: 1fr; }
  }
</style>
